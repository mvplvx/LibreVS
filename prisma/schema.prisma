generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users          User[]
  companies      Company[]
  portfolioViews PortfolioView[]
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
}

model Company {
  id                 String   @id @default(cuid())
  name               String
  registrationNumber String?
  country            String?
  industry           String?
  createdAt          DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  reportingPeriods ReportingPeriod[]
}

model ReportingPeriod {
  id        String    @id @default(cuid())
  year      Int
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("draft")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  sustainabilityDataPoints SustainabilityDataPoint[]

  createdAt DateTime @default(now())
}

model SustainabilityDataPoint {
  id String @id @default(cuid())

  reportingPeriodId String
  reportingPeriod   ReportingPeriod @relation(fields: [reportingPeriodId], references: [id])

  fieldId String
  value   String
  unit    String?

  createdAt DateTime @default(now())

  @@unique([reportingPeriodId, fieldId])
}

model PortfolioView {
  id   String @id @default(cuid())
  name String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  companyIds String
  createdAt  DateTime @default(now())
}
