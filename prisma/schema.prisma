generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  companies Company[]
  feedback  VsmeFeedback[]
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
}

model Company {
  id                 String   @id @default(cuid())
  name               String
  registrationNumber String?
  country            String?
  industry           String?
  /** Drives B/C applicability (workflow + export validation). */
  employeeCount      Int?
  createdAt          DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  reportingPeriods ReportingPeriod[]
}

model ReportingPeriod {
  id        String    @id @default(cuid())
  year      Int
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("draft")
  /** VSME registry version active when the period was created. */
  schemaVersion String @default("2.0.0")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  sustainabilityDataPoints SustainabilityDataPoint[]
  fieldMateriality       VsmeFieldMateriality[]
  exportSnapshots        VsmeExportSnapshot[]

  createdAt DateTime @default(now())
}

/** Immutable EFRAG export capture for audit and version history. */
model VsmeExportSnapshot {
  id String @id @default(cuid())

  reportingPeriodId String
  reportingPeriod   ReportingPeriod @relation(fields: [reportingPeriodId], references: [id], onDelete: Cascade)

  companyId String

  createdAt DateTime @default(now())

  stateSnapshot      Json
  exportData         Json
  validationResult   Json

  reportingState String
  coverage       Float

  isFinal Boolean @default(false)
  version Int

  @@unique([reportingPeriodId, version])
  @@index([reportingPeriodId])
  @@index([companyId])
}

/** Per-field materiality assessment (material vs non_material) for a reporting period. */
model VsmeFieldMateriality {
  id String @id @default(cuid())

  reportingPeriodId String
  reportingPeriod   ReportingPeriod @relation(fields: [reportingPeriodId], references: [id], onDelete: Cascade)

  fieldId String
  /** "material" | "non_material" */
  materiality String @default("material")

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([reportingPeriodId, fieldId])
}

model SustainabilityDataPoint {
  id String @id @default(cuid())

  reportingPeriodId String
  reportingPeriod   ReportingPeriod @relation(fields: [reportingPeriodId], references: [id])

  fieldId String
  value   String
  unit    String?

  /** Original v1 fieldId when row predates v2 registry (preserved for audit). */
  legacyFieldId   String?
  /** v2 registry fieldId when a known v1 id was mapped (fieldId may still hold v1). */
  migratedFieldId String?
  /** v1→v2 migration outcome; null for native v2 rows. */
  migrationStatus String?

  createdAt DateTime @default(now())

  @@unique([reportingPeriodId, fieldId])
}

/** Phase 6 — in-app feedback capture (no external integrations). */
model VsmeFeedback {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  reportingPeriodId String?
  fieldId           String?
  section           String?
  message           String

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([createdAt])
}
