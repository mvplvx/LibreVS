# Copy to .env for local development:
#   cp .env.example .env

# PostgreSQL (required)
DATABASE_URL=postgresql://librevs:librevs@localhost:5432/librevs?schema=public

# Structured stdout logs (1 = on, 0 = off)
LIBREVS_LOG=1

# Pilot / release exposure (optional)
LIBREVS_PILOT_MODE=1
NEXT_PUBLIC_LIBREVS_PILOT_MODE=true

# Docker entrypoint: run test-environment seed after migrate
# LIBREVS_SEED_TEST_ENV=1
